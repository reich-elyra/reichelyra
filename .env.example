# ──────────────────────────────────────────────────────────
# Reich Elyra — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Cloudflare Pages, add these in the dashboard:
#   Dashboard → Pages → reichelyra → Settings → Environment variables
# ──────────────────────────────────────────────────────────

# Google Analytics 4
# Get your Measurement ID from: https://analytics.google.com
#   Admin → Data Streams → Web → Measurement ID (starts with G-)
# Leave empty to disable analytics entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Formspree Contact Form
# Create a form at: https://formspree.io
#   Copy the endpoint URL (e.g. https://formspree.io/f/xABcdEfG)
# Leave empty to show a fallback email contact instead of the form.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
